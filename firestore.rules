rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper simplificado para evitar erros de latência
    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed() && (
        request.auth.token.email == "guilherme.jomed@gmail.com" ||
        request.auth.token.email == "gui@gmail.com"
      );
    }

    function getRole() {
      // Usando o getAuth para buscar o role de forma segura
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Bloqueio Global
    match /{document=**} {
      allow read, write: if false;
    }

    // Regra para Movimentação de Estoque e Itens
    match /stock_movements/{id} {
      allow read: if isAuthed();
      allow write: if isAuthed() && (isAdmin() || getRole() in ["SENIOR", "PLENO", "CREATOR"]);
    }

    match /stock_items/{id} {
      allow read: if isAuthed();
      allow write: if isAuthed() && (isAdmin() || getRole() in ["SENIOR", "PLENO", "CREATOR"]);
    }

    // Veículos e Pneus
    match /vehicles/{id} {
      allow read: if isAuthed();
      allow write: if isAuthed() && (isAdmin() || getRole() in ["SENIOR", "PLENO", "INSPECTOR", "CREATOR"]);
    }

    match /tires/{id} {
      allow read: if isAuthed();
      allow write: if isAuthed() && (isAdmin() || getRole() in ["SENIOR", "PLENO", "INSPECTOR", "CREATOR"]);
    }

    // Cadastros de Apoio (Liberando leitura para não travar o carregamento do App)
    match /collaborators/{id} { allow read: if isAuthed(); allow write: if isAdmin() || getRole() == "SENIOR"; }
    match /fuel_stations/{id} { allow read: if isAuthed(); allow write: if isAdmin(); }
    match /fuel_entries/{id} { allow read: if isAuthed(); allow write: if isAuthed(); }
    match /fuelTypes/{id} { allow read: if isAuthed(); allow write: if isAdmin(); }
    match /vehicleTypes/{id} { allow read: if isAuthed(); allow write: if isAdmin(); }
    match /classifications/{id} { allow read: if isAuthed(); allow write: if isAdmin(); }
    match /partners/{id} { allow read: if isAuthed(); allow write: if isAdmin(); }
    match /sectors/{id} { allow read: if isAuthed(); allow write: if isAdmin(); }

    // Manutenção e OS
    match /maintenance_plans/{id} { allow read: if isAuthed(); allow write: if isAdmin(); }
    match /maintenance_schedules/{id} { allow read: if isAuthed(); allow write: if isAuthed(); }
    match /service_orders/{id} { allow read: if isAuthed(); allow write: if isAuthed(); }

    // Usuários e Configurações
    match /users/{userId} {
      allow read: if isAuthed(); 
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    match /system_logs/{id} { allow read: if isAdmin(); allow create: if isAuthed(); }
    match /settings/{id} { allow read: if isAuthed(); allow write: if isAdmin(); }
    match /branches/{id} { allow read: if isAuthed(); allow write: if isAdmin(); }
  }
}
