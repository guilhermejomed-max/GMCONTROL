rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isVerified() {
      // Allowing isSignedIn to pass as verified temporarily since many users don't have verified emails yet.
      // We still check for request.auth to ensure they are logged in.
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Allow server-side operations (service account)
    function isServer() {
      return request.auth == null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "tnfDueAojpU7PJThDm6VAT1jRRA3" ||
        request.auth.token.email == "guilherme.jomed@gmail.com" ||
        request.auth.token.email == "gui@gmail.com" ||
        request.auth.token.email == "michel.henrique@sys.gmcontrol.com" ||
        request.auth.token.email == "danilo.silva@sys.gmcontrol.com" ||
        request.auth.token.email == "guilherme.martins@sys.gmcontrol.com" ||
        (request.auth.token.email != null && request.auth.token.email.matches(".*@sys\\.gmcontrol\\.com$"))
      );
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : {"allowedModules": ["TIRES", "VEHICLES", "MECHANICAL", "FUEL", "FINANCIAL"], "role": "SENIOR"};
    }

    function hasModuleAccess(module) {
      return isServer() || isAdmin() || (isSignedIn() && module in getUserData().get('allowedModules', ["TIRES", "VEHICLES", "MECHANICAL", "FUEL", "FINANCIAL"]));
    }

    function getRole() {
      return isServer() ? "SENIOR" : getUserData().get('role', 'SENIOR');
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn();
      allow write: if isVerified() && (request.auth.uid == userId || isAdmin());
    }

    // Validation Helpers
    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    function isValidNumber(val, min, max) {
      return val is number && val >= min && val <= max;
    }

    function hasFields(data, fields) {
      return data.keys().hasAll(fields);
    }

    // --- TIRES MODULE ---
    function isValidTire(data) {
      return hasFields(data, ['fireNumber', 'brand', 'model', 'status']) &&
             isValidString(data.fireNumber, 1, 50) &&
             isValidString(data.brand, 1, 50);
    }

    match /tires/{id} {
      allow read: if hasModuleAccess("TIRES");
      allow write: if hasModuleAccess("TIRES") && isValidTire(request.resource.data);
    }
    match /retread_orders/{id} {
      allow read: if hasModuleAccess("TIRES");
      allow write: if hasModuleAccess("TIRES");
    }
    match /retreaders/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isVerified() && getRole() in ["SENIOR", "PLENO", "CREATOR"]);
    }
    match /tread_patterns/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isVerified() && getRole() in ["SENIOR", "PLENO", "CREATOR"]);
    }
    match /tire_loans/{id} {
      allow read: if hasModuleAccess("TIRES");
      allow write: if hasModuleAccess("TIRES");
    }

    // --- VEHICLES MODULE ---
    function isValidVehicle(data) {
      return hasFields(data, ['plate', 'model', 'type']) &&
             isValidString(data.plate, 1, 20) &&
             isValidString(data.model, 1, 100);
    }

    match /vehicles/{id} {
      allow read: if hasModuleAccess("VEHICLES");
      allow write: if hasModuleAccess("VEHICLES") && isValidVehicle(request.resource.data);
    }
    match /vehicleBrandModels/{id} {
      allow read: if isSignedIn();
      allow write: if isVerified() && hasModuleAccess("VEHICLES");
    }
    match /vehicleTypes/{id} {
      allow read: if isSignedIn();
      allow write: if isVerified() && hasModuleAccess("VEHICLES");
    }
    match /drivers/{id} {
      allow read: if hasModuleAccess("VEHICLES");
      allow write: if hasModuleAccess("VEHICLES");
    }
    match /collaborators/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin() || getRole() in ["SENIOR", "PLENO", "CREATOR"]; 
    }
    match /arrival_alerts/{id} {
      allow read: if hasModuleAccess("VEHICLES");
      allow write: if hasModuleAccess("VEHICLES");
    }
    match /occurrences/{id} {
      allow read, create, update, delete: if hasModuleAccess("VEHICLES");
    }
    match /occurrence_reasons/{id} {
      allow read: if isSignedIn();
      allow write, delete: if isSignedIn() && (isVerified() || isAdmin());
    }

    // --- MECHANICAL MODULE ---
    match /service_orders/{id} {
      allow read: if hasModuleAccess("MECHANICAL");
      allow write: if hasModuleAccess("MECHANICAL");
    }
    match /maintenance_plans/{id} {
      allow read: if hasModuleAccess("MECHANICAL");
      allow write: if hasModuleAccess("MECHANICAL");
    }
    match /maintenance_schedules/{id} {
      allow read: if hasModuleAccess("MECHANICAL");
      allow write: if hasModuleAccess("MECHANICAL");
    }
    match /sectors/{id} {
      allow read: if isSignedIn();
      allow write, delete: if isVerified() && hasModuleAccess("MECHANICAL");
    }
    match /classifications/{id} {
      allow read: if isSignedIn();
      allow write, delete: if isVerified() && hasModuleAccess("MECHANICAL");
    }
    match /partners/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isVerified() && getRole() in ["SENIOR", "PLENO", "CREATOR"]);
    }
    match /stock_items/{id} {
      allow read: if isSignedIn();
      allow write: if isVerified();
    }
    match /stock_movements/{id} {
      allow read: if isSignedIn();
      allow write: if isVerified();
    }

    // --- FUEL MODULE ---
    match /fuel_entries/{id} { 
      allow read: if hasModuleAccess("FUEL"); 
      allow write: if hasModuleAccess("FUEL"); 
    }
    match /fuel_stations/{id} { 
      allow read: if hasModuleAccess("FUEL"); 
      allow write: if hasModuleAccess("FUEL"); 
    }
    match /fuelTypes/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isVerified() && hasModuleAccess("FUEL"); 
    }

    // --- FINANCIAL MODULE ---
    match /financial_records/{id} {
      allow read, write: if isVerified();
    }

    // --- PAYMENT METHODS ---
    function isValidPaymentMethod(data) {
      return hasFields(data, ['id', 'name']) &&
             isValidString(data.name, 1, 100);
    }

    match /payment_methods/{id} {
      allow read: if isSignedIn();
      allow write: if isVerified() && isValidPaymentMethod(request.resource.data);
    }

    // --- WASTE MANAGEMENT ---
    match /waste_types/{id} {
      allow read: if isSignedIn();
      allow write: if isVerified() && hasModuleAccess("MECHANICAL");
    }
    match /waste_disposals/{id} {
      allow read: if hasModuleAccess("MECHANICAL");
      allow write: if hasModuleAccess("MECHANICAL");
    }

    // --- NOTIFICATIONS ---
    match /notifications/{id} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.recipientId || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == resource.data.recipientId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    // --- SYSTEM ---
    match /system_logs/{id} { allow read: if isAdmin(); allow create: if isSignedIn(); }
    match /settings/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || (isVerified() && getRole() in ["SENIOR", "CREATOR"]); }
    match /branches/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || (isVerified() && getRole() in ["SENIOR", "CREATOR"]); }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
