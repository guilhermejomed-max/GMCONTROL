{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user profile",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique user ID (Firebase Auth UID)" },
        "name": { "type": "string", "description": "Full name" },
        "username": { "type": "string", "description": "Login username" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "role": { "type": "string", "enum": ["JUNIOR", "PLENO", "SENIOR", "CREATOR", "INSPECTOR"], "description": "Access level" },
        "allowedModules": { "type": "array", "items": { "type": "string" }, "description": "Modules the user can access" },
        "permissions": { "type": "array", "items": { "type": "string" }, "description": "Specific permissions" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation date" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login timestamp" },
        "branchId": { "type": "string", "description": "Linked branch ID" }
      },
      "required": ["id", "name", "username", "email", "role", "createdAt"]
    },
    "Tire": {
      "title": "Tire",
      "description": "Tire asset information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fireNumber": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "status": { "type": "string" },
        "totalKms": { "type": "number" },
        "currentTreadDepth": { "type": "number" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "fireNumber", "brand", "model", "status", "totalKms", "currentTreadDepth"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Vehicle asset information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "plate": { "type": "string" },
        "model": { "type": "string" },
        "type": { "type": "string", "enum": ["CAVALO", "CARRETA"] },
        "odometer": { "type": "number" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "plate", "model", "type", "odometer"]
    },
    "SystemLog": {
      "title": "SystemLog",
      "description": "Audit log for system actions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "module": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userName", "action", "details", "module", "timestamp"]
    },
    "VehicleBrandModel": {
      "title": "VehicleBrandModel",
      "description": "Brand and model definitions for vehicles",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" }
      },
      "required": ["id", "brand", "model"]
    },
    "Retreader": {
      "title": "Retreader",
      "description": "Retreading service providers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["name"]
    },
    "TreadPattern": {
      "title": "TreadPattern",
      "description": "Tire tread pattern definitions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "depth": { "type": "number" },
        "brand": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["name", "depth"]
    },
    "ServiceOrder": {
      "title": "ServiceOrder",
      "description": "Maintenance service orders",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicleId": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "items": { "type": "array" },
        "totalCost": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "vehicleId", "status", "createdAt"]
    },
    "StockItem": {
      "title": "StockItem",
      "description": "Items in stock",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "minQuantity": { "type": "number" },
        "unit": { "type": "string" },
        "category": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "name", "quantity"]
    },
    "Driver": {
      "title": "Driver",
      "description": "Vehicle drivers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "license": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "MaintenancePlan": {
      "title": "MaintenancePlan",
      "description": "Maintenance plans for vehicles",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "intervalKm": { "type": "number" },
        "intervalDays": { "type": "number" },
        "tasks": { "type": "array" }
      },
      "required": ["id", "name"]
    },
    "MaintenanceSchedule": {
      "title": "MaintenanceSchedule",
      "description": "Scheduled maintenance tasks",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicleId": { "type": "string" },
        "planId": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "vehicleId", "planId", "dueDate"]
    },
    "RetreadOrder": {
      "title": "RetreadOrder",
      "description": "Orders for tire retreading",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tireId": { "type": "string" },
        "retreaderId": { "type": "string" },
        "status": { "type": "string" },
        "sentDate": { "type": "string", "format": "date-time" },
        "expectedReturnDate": { "type": "string", "format": "date-time" },
        "actualReturnDate": { "type": "string", "format": "date-time" },
        "cost": { "type": "number" },
        "treadPatternId": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "tireId", "retreaderId", "status", "sentDate"]
    },
    "StockMovement": {
      "title": "StockMovement",
      "description": "Records of stock entries and exits",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "quantity": { "type": "number" },
        "type": { "type": "string", "enum": ["ENTRY", "EXIT"] },
        "date": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "reason": { "type": "string" },
        "serviceOrderId": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["itemId", "quantity", "type", "date", "userId"]
    },
    "Collaborator": {
      "title": "Collaborator",
      "description": "External or internal collaborators",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "SystemSettings": {
      "title": "SystemSettings",
      "description": "Global system configuration",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "language": { "type": "string" },
        "timezone": { "type": "string" },
        "notifications": { "type": "object" }
      }
    },
    "TrackerSettings": {
      "title": "TrackerSettings",
      "description": "Configuration for vehicle trackers",
      "type": "object",
      "properties": {
        "apiUrl": { "type": "string" },
        "user": { "type": "string" },
        "pass": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["apiUrl", "user", "pass", "active"]
    },
    "ArrivalAlert": {
      "title": "ArrivalAlert",
      "description": "Alerts for vehicle arrivals",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicleId": { "type": "string" },
        "locationId": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "arrivedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "vehicleId", "locationId", "status", "createdAt"]
    },
    "Branch": {
      "title": "Branch",
      "description": "Company branch information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cnpj": { "type": "string" },
        "location": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "code": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "cnpj", "location", "code", "createdAt"]
    },
    "VehicleType": {
      "title": "VehicleType",
      "description": "Dynamic vehicle type definitions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "axlesCount": { "type": "number" },
        "steerAxlesCount": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "axlesCount"]
    },
    "TireLoan": {
      "title": "TireLoan",
      "description": "Records of tire loans",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tireId": { "type": "string" },
        "borrowerId": { "type": "string" },
        "status": { "type": "string" },
        "loanDate": { "type": "string", "format": "date-time" },
        "returnDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "tireId", "borrowerId", "status", "loanDate"]
    },
    "OccurrenceReason": {
      "title": "OccurrenceReason",
      "description": "Reasons for vehicle occurrences (e.g., breakdown, accident)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Occurrence": {
      "title": "Occurrence",
      "description": "Vehicle occurrences/incidents",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicleId": { "type": "string" },
        "reasonId": { "type": "string" },
        "description": { "type": "string" },
        "responsibleSector": { "type": "string" },
        "responsibleSectorId": { "type": "string" },
        "assignedUserId": { "type": "string" },
        "assignedUserName": { "type": "string" },
        "status": { "type": "string", "enum": ["OPEN", "ACCEPTED", "REJECTED", "RESOLVED"] },
        "rejectionReason": { "type": "string" },
        "treatments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "userId": { "type": "string" },
              "userName": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "resolvedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "vehicleId", "reasonId", "status", "createdAt", "userId", "treatments"]
    },
    "FuelEntry": {
      "title": "FuelEntry",
      "description": "Vehicle fuel transaction records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicleId": { "type": "string" },
        "vehiclePlate": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "odometer": { "type": "number" },
        "liters": { "type": "number" },
        "unitPrice": { "type": "number" },
        "totalCost": { "type": "number" },
        "fuelType": { "type": "string" },
        "stationName": { "type": "string" },
        "stationCnpj": { "type": "string" },
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "branchId": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "vehicleId", "date", "odometer", "liters", "unitPrice", "totalCost"]
    },
    "FuelStation": {
      "title": "FuelStation",
      "description": "Registered fueling stations",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cnpj": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "branchId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "cnpj", "createdAt"]
    },
    "FuelType": {
      "title": "FuelType",
      "description": "Types of fuel",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Partner": {
      "title": "Partner",
      "description": "Service partners and suppliers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "services": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "cost": { "type": "number" }
            }
          }
        },
        "branchId": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "ServiceSector": {
      "title": "ServiceSector",
      "description": "Service sectors",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "ServiceClassification": {
      "title": "ServiceClassification",
      "description": "Service classifications",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "FinancialRecord": {
      "title": "FinancialRecord",
      "description": "Financial records for vehicles or branches",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicleId": { "type": "string" },
        "branchId": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["PENDING", "PAID", "CANCELLED"] },
        "relatedId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["id", "category", "description", "amount", "date", "status", "createdAt", "createdBy"]
    },
    "PaymentMethod": {
      "title": "PaymentMethod",
      "description": "Payment methods for occurrences",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "WasteType": {
      "title": "WasteType",
      "description": "Types of waste generated in the workshop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "unit": { "type": "string", "enum": ["KG", "LITERS", "UNITS", "METERS"] },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["WASTE", "PPE", "TIRE"] }
      },
      "required": ["id", "name", "unit", "category"]
    },
    "WasteDisposal": {
      "title": "WasteDisposal",
      "description": "Waste disposal transaction records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "wasteTypeId": { "type": "string" },
              "wasteTypeName": { "type": "string" },
              "quantity": { "type": "number" },
              "unit": { "type": "string" }
            },
            "required": ["wasteTypeId", "quantity", "unit"]
          }
        },
        "date": { "type": "string", "format": "date" },
        "responsibleId": { "type": "string" },
        "responsibleName": { "type": "string" },
        "partnerId": { "type": "string" },
        "partnerName": { "type": "string" },
        "notes": { "type": "string" },
        "certificateNumber": { "type": "string" },
        "cost": { "type": "number" },
        "attachmentUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "disposalType": { "type": "string", "enum": ["WASTE", "PPE", "TIRE"] }
      },
      "required": ["id", "items", "date", "responsibleId", "partnerId", "createdAt", "disposalType"]
    },
    "PpeStockItem": {
      "title": "PpeStockItem",
      "description": "PPE items in stock for Occupational Safety",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "minQuantity": { "type": "number" },
        "unit": { "type": "string" },
        "caNumber": { "type": "string", "description": "Certificado de Aprovação (CA)" },
        "description": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "quantity", "unit"]
    },
    "HealthRecord": {
      "title": "HealthRecord",
      "description": "Employee health and ambulatory records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "collaboratorId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["ADMISSION", "PERIODIC", "RETURN_TO_WORK", "FUNCTION_CHANGE", "DISMISSAL", "CLINICAL_VISIT"] },
        "symptoms": { "type": "string" },
        "diagnosis": { "type": "string" },
        "observations": { "type": "string" },
        "status": { "type": "string", "enum": ["FIT", "UNFIT", "RESTRICTED"] },
        "doctorName": { "type": "string" },
        "doctorCrm": { "type": "string" },
        "asoExpirationDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "collaboratorId", "date", "type", "status"]
    }
  },
