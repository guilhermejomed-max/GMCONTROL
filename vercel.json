{
  "rewrites": [
    {
      "source": "/proxy-sascar/:path*",
      "destination": "https://api.sascar.com.br/:path*"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/**/*": {
      "includeFiles": "api/sascar-wsdl.xml"
    }
  }
}
