{
  "rewrites": [
    {
      "source": "/api/sascar/vehicles",
      "destination": "/api/sascar"
    },
    {
      "source": "/proxy-sascar/:path*",
      "destination": "https://sasintegra.sascar.com.br/SasIntegra/:path*"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/sascar.ts": {
      "maxDuration": 30
    }
  }
}
