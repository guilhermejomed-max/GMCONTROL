{
  "rewrites": [
    {
      "source": "/api/sascar/vehicles",
      "destination": "/api/sascar-vehicles"
    },
    {
      "source": "/proxy-sascar/:path*",
      "destination": "https://sasintegra.sascar.com.br/SasIntegra/:path*"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "api/sascar-wsdl.xml",
      "maxDuration": 60
    }
  }
}
